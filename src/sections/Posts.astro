---
// Posts-E: Featured Magazine Layout - Design de portal de notícias
import { getAllPosts } from '../lib/posts';
interface Props { title: string; limit: number; btnText: string; btnLink: string; }
const { title, limit, btnText, btnLink } = Astro.props;

const allPosts = await getAllPosts();
const featuredPost = allPosts[0];
const sidebarPosts = allPosts.slice(1, Math.min(limit, 4));
---
<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Header -->
    <div class="flex items-end justify-between mb-16">
      <div class="max-w-2xl">
        <span class="text-primary font-black uppercase tracking-[0.3em] text-[10px] mb-4 block">Destaques Editoriais</span>
        <h2 class="text-4xl md:text-6xl font-black text-dark tracking-tighter leading-none">{title}</h2>
      </div>
      <a href={btnLink} class="hidden md:flex items-center gap-3 text-sm font-black text-dark hover:text-primary transition-all uppercase tracking-widest border-b-2 border-primary/20 pb-1">
        {btnText}
      </a>
    </div>

    <!-- Magazine Grid -->
    <div class="grid lg:grid-cols-12 gap-12 items-start">
      
      <!-- Main Featured Post -->
      {featuredPost && (
        <article class="lg:col-span-7 group flex flex-col gap-8">
           <a href={`/${featuredPost.slug}`} class="block aspect-video rounded-[2.5rem] overflow-hidden shadow-2xl relative">
              <img
                src={featuredPost.heroImage}
                alt={featuredPost.title}
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-10 left-10 text-white">
                <span class="px-3 py-1 bg-primary text-[10px] font-black uppercase tracking-widest rounded-lg mb-4 inline-block shadow-lg">{featuredPost.category || 'Destaque'}</span>
                <h3 class="text-3xl md:text-4xl font-black leading-tight tracking-tight mt-2">{featuredPost.title}</h3>
              </div>
           </a>
           <p class="text-xl text-gray-500 leading-relaxed font-medium">
             {featuredPost.description}
           </p>
           <div class="flex items-center gap-4 border-t border-gray-100 pt-8">
              <div class="text-sm font-black text-dark uppercase tracking-widest leading-none">01 Minuto de Leitura</div>
              <div class="h-px w-24 bg-gray-200"></div>
              <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">{new Date(featuredPost.pubDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}</div>
           </div>
        </article>
      )}

      <!-- Sidebar Posts -->
      <div class="lg:col-span-5 flex flex-col gap-10">
        {sidebarPosts.map((post) => (
          <article class="group flex gap-6 items-start pb-10 border-b border-gray-50 last:border-0 last:pb-0">
             <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-gray-100 rounded-3xl overflow-hidden relative shadow-sm">
                <img src={post.heroImage} class="w-full h-full object-cover transition-transform group-hover:scale-110" alt={post.title} />
                <div class="absolute inset-0 bg-dark/20 group-hover:opacity-0 transition-opacity"></div>
             </div>
             <div class="flex flex-col gap-2">
                <span class="text-[9px] font-black uppercase text-primary tracking-widest">{post.category || 'Blog'}</span>
                <h3 class="text-lg font-black text-dark leading-tight tracking-tight group-hover:text-primary transition-colors">
                   <a href={`/${post.slug}`}>{post.title}</a>
                </h3>
                <div class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">{new Date(post.pubDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short' })}</div>
             </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>