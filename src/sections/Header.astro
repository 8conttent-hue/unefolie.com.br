---
// Header-E: Modern Split - Logo centro, links divididos
import siteConfig from '../data/siteConfig.json';
import { getAllPosts } from '../lib/posts';

const { name, menu: baseMenu = [] } = siteConfig;

// Buscar categorias REAIS do banco de dados (SSR)
const allPosts = await getAllPosts();
const realCategories = [...new Set(allPosts.map(p => p.category))].filter(Boolean);

// Injetar categorias reais no item "Blog" do menu
const menu = baseMenu.map((item: any) => {
  if (item.label.toLowerCase() === 'blog' || item.href === '/blog') {
    return {
      ...item,
      children: realCategories.length
        ? realCategories.map(cat => ({
            label: cat,
            href: `/categoria/${cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-')}`
          }))
        : undefined,
    };
  }
  return item;
});

// Divide o menu em duas partes para o desktop
const half = Math.ceil(menu.length / 2);
const leftMenu = menu.slice(0, half);
const rightMenu = menu.slice(half);
---
<header class="bg-white border-b border-gray-100 sticky top-0 z-[100]">
  <div class="max-w-6xl mx-auto px-4 h-20 flex items-center justify-between">
    
    <!-- Desktop Left Menu -->
    <nav class="hidden md:flex items-center gap-8 w-1/3">
      {leftMenu.map((item: any) => (
        item.children?.length ? (
          <div class="relative group flex items-center h-full">
            <button type="button" class="flex items-center gap-1 text-sm font-semibold text-gray-500 group-hover:text-primary transition-colors uppercase tracking-wider cursor-pointer">
              {item.label}
              <svg class="w-3 h-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="absolute top-full left-0 z-[110] pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <div class="w-44 bg-white border border-gray-100 shadow-xl rounded-xl py-2">
                <a href={item.href} class="block px-4 py-2 text-[10px] font-bold text-gray-400 uppercase tracking-tight border-b border-gray-50 mb-1">Ver tudo</a>
                {item.children.map((child: any) => (
                  <a href={child.href} class="block px-4 py-2 text-xs font-bold text-gray-500 hover:text-primary hover:bg-gray-50 transition-colors uppercase">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href} class="text-sm font-semibold text-gray-500 hover:text-primary transition-colors uppercase tracking-wider">
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- Logo Centro -->
    <div class="flex-1 flex justify-center">
      <a href="/" class="flex flex-col items-center group">
        <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white text-xl font-black group-hover:rotate-12 transition-transform shadow-md">
          {name.charAt(0).toUpperCase()}
        </div>
        <span class="font-black text-lg tracking-tighter mt-1 text-dark uppercase">{name}</span>
      </a>
    </div>

    <!-- Desktop Right Menu -->
    <nav class="hidden md:flex items-center justify-end gap-8 w-1/3">
      {rightMenu.map((item: any) => (
        item.children?.length ? (
          <div class="relative group flex items-center h-full">
            <button type="button" class="flex items-center gap-1 text-sm font-semibold text-gray-500 group-hover:text-primary transition-colors uppercase tracking-wider cursor-pointer">
              {item.label}
              <svg class="w-3 h-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="absolute top-full right-0 z-[110] pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <div class="w-44 bg-white border border-gray-100 shadow-xl rounded-xl py-2">
                <a href={item.href} class="block px-4 py-2 text-[10px] font-bold text-gray-400 uppercase tracking-tight border-b border-gray-50 mb-1">Ver tudo</a>
                {item.children.map((child: any) => (
                  <a href={child.href} class="block px-4 py-2 text-xs font-bold text-gray-500 hover:text-primary hover:bg-gray-50 transition-colors uppercase">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href} class="text-sm font-semibold text-gray-500 hover:text-primary transition-colors uppercase tracking-wider">
            {item.label}
          </a>
        )
      ))}
      <a href="/blog" class="ml-4 p-2 text-primary hover:bg-primary/10 rounded-full transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button id="menu-btn-e" class="md:hidden p-2 text-dark" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu-e" class="hidden md:hidden bg-white border-t border-gray-100 p-4 space-y-4">
    {menu.map((item: any) => (
      <div>
        <a href={item.href} class="block text-base font-medium text-gray-700">{item.label}</a>
        {item.children?.length ? (
          <div class="pl-4 mt-2 space-y-2 border-l-2 border-gray-100">
            {item.children.map((child: any) => (
              <a href={child.href} class="block text-sm text-gray-600 hover:text-primary">{child.label}</a>
            ))}
          </div>
        ) : null}
      </div>
    ))}
    <a href="/blog" class="block py-3 px-4 bg-primary text-white text-center rounded-xl font-bold">Ver Blog</a>
  </div>
</header>

<script>
  document.getElementById('menu-btn-e')?.addEventListener('click', () => {
    document.getElementById('mobile-menu-e')?.classList.toggle('hidden');
  });
</script>