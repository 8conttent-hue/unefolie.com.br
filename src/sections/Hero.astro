---
// Hero-H: Organic Shapes - Design com curvas e gradientes
interface Props {
  title: string;
  subtitle: string;
  btnText: string;
  btnLink: string;
  bgImage: string;
}
const { title, subtitle, btnText, btnLink, bgImage } = Astro.props;
---
<section class="relative bg-gradient-to-br from-dark to-[#1a1c2e] overflow-hidden py-24 lg:py-32">
  <!-- Organic Background Shapes -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/20 blur-[120px] rounded-full animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-accent/20 blur-[120px] rounded-full"></div>
    <!-- Simple Pattern Overlay -->
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 30px 30px;"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 grid lg:grid-cols-2 gap-16 items-center relative z-10">
    <!-- Image Side (Left on Desktop) -->
    <div class="order-2 lg:order-1">
      <div class="relative group">
         <!-- Mask with curvy border -->
        <div class="relative rounded-[2rem] lg:rounded-[4rem] lg:rounded-tr-[10rem] overflow-hidden shadow-2xl">
          <img src={bgImage} class="w-full h-[400px] lg:h-[500px] object-cover transition-transform duration-700 group-hover:scale-110" alt="Hero Featured" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-transparent to-transparent"></div>
        </div>
        <!-- Decorative border/outline -->
        <div class="absolute -inset-3 rounded-[2.5rem] lg:rounded-[4.5rem] lg:rounded-tr-[10.5rem] border-2 border-primary/30 -z-10 translate-x-3 translate-y-3 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
      </div>
    </div>

    <!-- Text Side -->
    <div class="order-1 lg:order-2 text-center lg:text-left">
      <h1 class="text-4xl md:text-6xl font-black text-white leading-tight mb-8">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-300">
          {title.split(' ')[0]}
        </span>
        {title.substring(title.indexOf(' '))}
      </h1>
      <p class="text-lg text-white/60 mb-10 leading-relaxed font-medium">
        {subtitle}
      </p>
      <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
        <a href={btnLink} class="px-10 py-5 bg-gradient-to-r from-primary to-accent text-white font-black rounded-full hover:shadow-[0_0_30px_rgba(var(--color-primary),0.5)] transition-all uppercase tracking-widest text-xs">
          {btnText}
        </a>
      </div>
    </div>
  </div>

  <!-- Section Curve -->
  <div class="absolute bottom-0 left-0 w-full leading-[0]">
    <svg class="relative block w-[calc(100%+1.3px)] h-[80px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C58.47,105.77,117.15,108.85,175.52,107.05,244.62,104.85,286,87.35,321.39,56.44Z" class="fill-white"></path>
    </svg>
  </div>
</section>