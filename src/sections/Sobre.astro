---
// Sobre-D: Timeline Histórica - Design de trajetória e marcos
interface Stat { value: string; label: string; }
interface Props {
  title: string;
  desc: string;
  image: string;
  stats: Stat[];
  content?: string;
}
const { title, desc, stats, content } = Astro.props;

const milestones = [
  { year: '2022', title: 'Início da Pesquisa', desc: 'Identificação da necessidade de análise de mídias curtas na saúde.' },
  { year: '2023', title: 'Coleta Netnográfica', desc: 'Análise de mais de 500 perfis sobre TEA no Instagram e TikTok.' },
  { year: '2024', title: 'Publicação Científica', desc: 'Resultados preliminares compartilhados em congressos de enfermagem.' },
  { year: '2025', title: 'Expansão Digital', desc: 'Lançamento desta plataforma para disseminação de cuidado especializado.' }
];
---
<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-24">
      <h1 class="text-5xl md:text-7xl font-black text-dark tracking-tighter mb-8 leading-none italic uppercase">{title}</h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto font-medium leading-relaxed italic">
        "{desc}"
      </p>
      {content && <p class="text-gray-600 leading-relaxed mt-6 max-w-2xl mx-auto">{content}</p>}
    </div>

    <!-- Timeline Body -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Vertical line -->
      <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px bg-gray-100"></div>

      <div class="space-y-32">
        {milestones?.map((m, i) => (
          <div class={`relative flex items-center justify-between gap-12 group ${i % 2 === 0 ? 'flex-row-reverse' : ''}`}>
            
            <!-- Content side -->
            <div class="w-1/2 group-hover:scale-105 transition-transform duration-500">
               <div class={`p-10 rounded-3xl bg-gray-50 border border-gray-100 shadow-sm relative ${i % 2 === 0 ? 'text-left' : 'text-right'}`}>
                  <!-- Year badge -->
                  <div class={`absolute top-0 -translate-y-1/2 px-4 py-1.5 bg-primary text-white text-xs font-black rounded-lg shadow-xl ${i % 2 === 0 ? 'left-8' : 'right-8'}`}>
                     {m.year}
                  </div>
                  <h3 class="text-2xl font-black text-dark mb-4 tracking-tight uppercase leading-none">{m.title}</h3>
                  <p class="text-sm text-gray-400 font-medium leading-relaxed">{m.desc}</p>
               </div>
            </div>

            <!-- Bullet point -->
            <div class="absolute left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-white border-4 border-primary shadow-xl z-10 group-hover:scale-[1.5] transition-transform"></div>

            <!-- Empty side for balance -->
            <div class="w-1/2"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Stats row -->
    <div class="mt-40 grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats?.map(s => (
        <div class="text-center group">
           <div class="text-4xl md:text-5xl font-black text-dark mb-2 group-hover:text-primary transition-colors tracking-tighter">{s.value}</div>
           <div class="text-[10px] font-black uppercase text-gray-300 tracking-widest">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>