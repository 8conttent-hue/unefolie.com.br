---
// Footer-C: Dark com newsletter
import siteConfig from '../data/siteConfig.json';
const { name, email = '', menu = [] } = siteConfig as any;
const year = new Date().getFullYear();
---
<footer class="bg-gradient-to-br from-dark via-accent to-dark text-white">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- Newsletter banner -->
    <div class="bg-white/5 border border-white/10 rounded-3xl p-8 md:p-12 mb-16 text-center">
      <h3 class="text-2xl md:text-3xl font-black mb-3">Receba nosso conteúdo em primeira mão</h3>
      <p class="text-white/60 mb-8">Junte-se a milhares de leitores que recebem os melhores posts toda semana.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="seu@email.com"
          class="flex-1 px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-primary text-sm"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-primary text-white font-bold rounded-xl hover:opacity-90 transition-opacity shrink-0"
        >
          Inscrever-se
        </button>
      </form>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Brand -->
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center text-white font-black">
          {name.charAt(0).toUpperCase()}
        </div>
        <div>
          <div class="font-bold">{name}</div>
          {email && <div class="text-white/40 text-xs">{email}</div>}
        </div>
      </div>

      <!-- Nav -->
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        {menu.map((item: any) => (
          <a href={item.href} class="text-sm text-white/60 hover:text-white transition-colors">{item.label}</a>
        ))}
        <a href="/privacidade" class="text-sm text-white/60 hover:text-white transition-colors">Privacidade</a>
        <a href="/contato" class="text-sm text-white/60 hover:text-white transition-colors">Contato</a>
      </nav>

      <!-- Copyright -->
      <p class="text-white/40 text-sm shrink-0">© {year} {name}</p>
    </div>
  </div>
</footer>